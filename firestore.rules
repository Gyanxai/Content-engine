rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role in ['super_admin', 'admin'];
    }

    function canBuildCurriculum() {
      return isSignedIn() &&
        (request.auth.token.role in ['super_admin', 'admin'] ||
          'curriculum_builder' in request.auth.token.permissions);
    }

    function isReviewer() {
      return isSignedIn() &&
        (request.auth.token.role in ['super_admin', 'admin', 'reviewer'] ||
          'review_publish' in request.auth.token.permissions);
    }

    function isContentStaff() {
      return isSignedIn() &&
        (request.auth.token.role in ['super_admin', 'admin', 'creator', 'reviewer']);
    }

    function canManageAdmins() {
      return isSignedIn() &&
        (request.auth.token.role == 'super_admin' || 'manage_admins' in request.auth.token.permissions);
    }

    // ── User profiles ───────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:  if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) &&
                       !('role' in request.resource.data) &&
                       !('custom_claims' in request.resource.data)
                    || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Adaptive Learning Engine (Student Data) ──────────────────────────────
    match /user_progress/{docId} {
      // docId is userId_conceptId
      allow read, write: if isSignedIn() && docId.startsWith(request.auth.uid);
    }

    match /user_attempts/{attemptId} {
      allow create: if isOwner(request.resource.data.user_id);
      allow read: if (isSignedIn() && resource.data.user_id == request.auth.uid) || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /user_reviews/{docId} {
      allow read, write: if isSignedIn() && docId.startsWith(request.auth.uid);
    }

    match /analytics_events/{eventId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    // ── Curriculum and content engine ───────────────────────────────────────
    match /curricula/{docId} {
      allow read: if isSignedIn() &&
                    (resource.data.state == 'published' || isContentStaff());
      allow create, update, delete: if canBuildCurriculum();
    }

    match /chapters/{chapterId} {
      allow read: if isSignedIn() &&
                    (resource.data.state == 'published' || isContentStaff());
      allow create, update, delete: if canBuildCurriculum();
    }

    match /topics/{topicId} {
      allow read: if isSignedIn();
      allow create, update, delete: if canBuildCurriculum();
    }

    match /subtopics/{subtopicId} {
      allow read: if isSignedIn() &&
                    (resource.data.state == 'published' || isContentStaff());
      allow create, update, delete: if canBuildCurriculum();
    }

    match /content_items/{contentId} {
      allow read: if isSignedIn() &&
                    (resource.data.state == 'published' || isContentStaff());
      allow create: if isContentStaff();
      allow update: if isContentStaff() &&
                    (
                      !('state' in request.resource.data.diff(resource.data).changedKeys()) ||
                      request.resource.data.state in ['draft', 'review'] ||
                      isReviewer()
                    );
      allow delete: if canBuildCurriculum();
    }

    match /content_versions/{versionId} {
      allow read: if isContentStaff();
      allow create: if isContentStaff();
      allow update, delete: if false;
    }

    match /content_issues/{issueId} {
      allow read: if isContentStaff();
      allow create: if isSignedIn();
      allow update, delete: if canBuildCurriculum();
    }

    // ── Leaderboard (public read, admin write) ───────────────────────────────
    match /leaderboard/{entryId} {
      allow read:  if isSignedIn();
      allow write: if request.auth.token.role == 'super_admin';
    }

    // ── Admin Management (Super Admin only) ──────────────────────────────────
    match /admins/{adminId} {
      allow read: if isOwner(adminId) || canManageAdmins();
      allow write: if canManageAdmins();
    }

    // ── Catch-all: deny everything else ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
